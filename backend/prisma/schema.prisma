generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User 模型 — 对应数据库中的 users 表
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt     @map("updated_at")

  roles     Role[]   // 多对多：一个用户可以有多个角色
  jobPostTemplates JobPostTemplate[]
  jobPosts  JobPost[]
  applicantInfo ApplicantInformation?
  applications Application[]
  notifications Notification[]

  @@map("users")
}

// Role 模型 — 角色表
model Role {
  id          Int          @id @default(autoincrement())
  name        String       @unique  // 角色名，如 "admin", "editor"
  description String?               // 角色描述
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt     @map("updated_at")

  users       User[]       // 多对多：一个角色可以分配给多个用户
  permissions Permission[] // 多对多：一个角色可以有多个权限

  @@map("roles")
}

// Permission 模型 — 权限表
model Permission {
  id          Int      @id @default(autoincrement())
  name        String   @unique  // 权限名，如 "user:read", "user:write"
  description String?           // 权限描述
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt     @map("updated_at")

  roles       Role[]   // 多对多：一个权限可以属于多个角色

  @@map("permissions")
}

// Dictionary 模型 — 字典表
model Dictionary {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String[]
  category  String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("dictionaries")
}

// AuditTrail 模型 — 审计日志表
model AuditTrail {
  id        Int      @id @default(autoincrement())
  table     String
  recordId  Int      @map("record_id")
  field     String
  oldValue  String?  @map("old_value")
  newValue  String?  @map("new_value")
  userId    Int      @map("user_id")
  userEmail String   @map("user_email")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([table, recordId])
  @@map("audit_trails")
}

// JobPostTemplate 模型 — 职位发布模板
model JobPostTemplate {
  id           Int      @id @default(autoincrement())
  templateName String   @map("template_name")
  fields       Json     @default("[]") // [{title, type, required}]
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt     @map("updated_at")

  userId       Int      @map("user_id")
  user         User     @relation(fields: [userId], references: [id])

  @@map("job_post_templates")
}

enum JobPostState {
  active
  closed
}

// JobPost 模型 — 职位发布
model JobPost {
  id             Int          @id @default(autoincrement())
  title          String
  jobDescription String       @map("job_description")
  state          JobPostState @default(active)
  questions      Json     @default("[]") // same as template fields: [{title, type, required, options?}]
  postedAt       DateTime @default(now()) @map("posted_at")
  postedBy       String   @map("posted_by")
  reviewer       String[]   @default([])
  collector      Int[]      @default([])  // user IDs who collected/favorited this post
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt     @map("updated_at")

  userId         Int      @map("user_id")
  user           User     @relation(fields: [userId], references: [id])

  applications   Application[]

  @@map("job_posts")
}

// ApplicantInformation 模型 — 申请人基本信息
model ApplicantInformation {
  id        Int      @id @default(autoincrement())
  email     String
  phone     String
  nickname  String
  country   String
  state     String
  address   String
  postcode  String
  resume    String   @default("") // file path or URL
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt     @map("updated_at")

  userId    Int      @unique @map("user_id")
  user      User     @relation(fields: [userId], references: [id])

  @@map("applicant_information")
}

enum ApplicationState {
  applied
  rejected
  reviewed
}

// Application 模型 — 职位申请
model Application {
  id        Int               @id @default(autoincrement())
  answers   Json              @default("[]") // 自定义问题的回答: [{title, value}]
  state     ApplicationState  @default(applied)
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt     @map("updated_at")

  userId    Int               @map("user_id")
  user      User              @relation(fields: [userId], references: [id])

  jobPostId Int               @map("job_post_id")
  jobPost   JobPost           @relation(fields: [jobPostId], references: [id])

  @@unique([userId, jobPostId]) // 每个用户每个职位只能申请一次
  @@map("applications")
}

// Notification 模型 — 通知
model Notification {
  id        Int      @id @default(autoincrement())
  message   String
  url       String   @default("")
  reviewed  Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt     @map("updated_at")

  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id])

  @@map("notifications")
}
