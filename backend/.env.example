# PartnerHub 后端环境变量模板
# 复制此文件为 .env 并填写真实值
# cp .env.example .env

# 数据库连接字符串
# 本地: postgresql://postgres:postgres@localhost:5432/partnerhub
# Neon: 在 https://console.neon.tech 创建项目后获取
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/partnerhub"

# 后端服务端口
PORT=3001

# 前端地址（CORS 白名单）
# 本地: http://localhost:3000
# 线上: 你的 Vercel 域名，如 https://partnerhub.vercel.app
FRONTEND_URL="http://localhost:3000"
